{{- if (eq .chezmoi.os "darwin") -}}
  #!/bin/bash
  set -euo pipefail

  # Setting environment variable for where brewfile can be found to make sure the script can find it
  export HOMEBREW_BUNDLE_FILE=$HOME/.Brewfile

  # Install Homebrew
  if ! command -v brew &> /dev/null; then
    echo '🍺  Installing Homebrew'
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"

    # Export environment variables after install
    echo '🍺  Setting path'
    eval "$(/opt/homebrew/bin/brew shellenv)"
  fi

  # Refresh tap metadata so brew bundle sees current cask versions
  brew update

  # Install brew bundles
  echo "🍻 Installing homebrew packages"
  brew bundle install

  # Verify every brewfile entry actually installed; brew bundle install can exit
  # 0 even when individual installs fail (e.g. a missing tap formula prints a
  # warning but doesn't propagate). Fail loudly here.
  brew bundle check --verbose

  brew bundle --force cleanup
{{ end -}}
