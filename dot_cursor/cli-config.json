{
  "approvalMode": "allowlist",
  "permissions": {
    "allow": [
      "Shell(ls*{,/**})",
      "Shell(cat*{,/**})",
      "Shell(head*{,/**})",
      "Shell(tail*{,/**})",
      "Shell(less*{,/**})",
      "Shell(pwd)",
      "Shell(tree*{,/**})",
      "Shell(find*{,/**})",
      "Shell(grep*{,/**})",
      "Shell(rg*{,/**})",
      "Shell(fd*{,/**})",
      "Shell(file*{,/**})",
      "Shell(stat*{,/**})",
      "Shell(wc*{,/**})",
      "Shell(sort*{,/**})",
      "Shell(uniq*{,/**})",
      "Shell(cut*{,/**})",
      "Shell(awk*{,/**})",
      "Shell(tr*{,/**})",
      "Shell(diff*{,/**})",
      "Shell(which*{,/**})",
      "Shell(command*{,/**})",
      "Shell(type*{,/**})",
      "Shell(echo*{,/**})",
      "Shell(printf*{,/**})",
      "Shell(date*{,/**})",
      "Shell(env*{,/**})",
      "Shell(printenv*{,/**})",
      "Shell(jq*{,/**})",
      "Shell(yq*{,/**})",
      "Shell(make*{,/**})",

      "Shell(git*{,/**})",

      "Shell(glab*{,/**})",

      "Shell(npm test*{,/**})",
      "Shell(npm run*{,/**})",
      "Shell(npm list*{,/**})",
      "Shell(npm ls*{,/**})",
      "Shell(npm view*{,/**})",
      "Shell(npm outdated*{,/**})",
      "Shell(npm audit*{,/**})",
      "Shell(pnpm test*{,/**})",
      "Shell(pnpm run*{,/**})",
      "Shell(pnpm list*{,/**})",
      "Shell(pnpm ls*{,/**})",
      "Shell(pnpm audit*{,/**})",
      "Shell(yarn test*{,/**})",
      "Shell(yarn run*{,/**})",
      "Shell(yarn list*{,/**})",
      "Shell(yarn audit*{,/**})",
      "Shell(npx*{,/**})",
      "Shell(node*{,/**})",
      "Shell(tsc*{,/**})",
      "Shell(eslint*{,/**})",
      "Shell(prettier --check*{,/**})",

      "Shell(pytest*{,/**})",
      "Shell(python*{,/**})",
      "Shell(python3*{,/**})",
      "Shell(uv run*{,/**})",
      "Shell(uv sync*{,/**})",
      "Shell(uv lock*{,/**})",
      "Shell(uv tree*{,/**})",
      "Shell(uv pip list*{,/**})",
      "Shell(uv pip show*{,/**})",
      "Shell(uv pip freeze*{,/**})",
      "Shell(ruff*{,/**})",
      "Shell(black --check*{,/**})",
      "Shell(mypy*{,/**})",

      "Shell(terraform plan*{,/**})",
      "Shell(terraform validate*{,/**})",
      "Shell(terraform fmt --check*{,/**})",
      "Shell(terraform show*{,/**})",
      "Shell(terraform state list*{,/**})",
      "Shell(terraform state show*{,/**})",
      "Shell(terraform output*{,/**})",
      "Shell(terraform providers*{,/**})",
      "Shell(terraform version*{,/**})",
      "Shell(terragrunt plan*{,/**})",
      "Shell(terragrunt validate*{,/**})",
      "Shell(terragrunt show*{,/**})",
      "Shell(tofu plan*{,/**})",
      "Shell(tofu validate*{,/**})",
      "Shell(tofu show*{,/**})",
      "Shell(tflint*{,/**})"
    ],
    "deny": [
      "Shell(git push*{,/**})",
      "Shell(glab mr merge*{,/**})",
      "Shell(glab mr create*{,/**})",
      "Shell(glab mr close*{,/**})",
      "Shell(glab mr update*{,/**})",
      "Shell(glab mr approve*{,/**})",
      "Shell(glab mr rebase*{,/**})",
      "Shell(glab issue create*{,/**})",
      "Shell(glab issue close*{,/**})",
      "Shell(glab issue update*{,/**})",
      "Shell(glab repo create*{,/**})",
      "Shell(glab repo delete*{,/**})",
      "Shell(rm*{,/**})",
      "Shell(sudo*{,/**})",
      "Shell(curl*{,/**})",
      "Shell(wget*{,/**})",
      "Shell(ssh*{,/**})",
      "Shell(scp*{,/**})",
      "Shell(rsync*{,/**})",
      "Shell(nc*{,/**})",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*.key)",
      "Read(**/*.pem)",
      "Read(**/.ssh/id_*)",
      "Read(**/.aws/credentials)",
      "Read(**/.netrc)",
      "Read(**/.npmrc)",
      "Read(**/.pypirc)",
      "Write(**/.env)",
      "Write(**/.env.*)",
      "Write(**/*.key)",
      "Write(**/*.pem)",
      "Write(**/.ssh/**)"
    ]
  },
  "webFetchDomainAllowlist": [
    "gitlab.com",
    "github.com"
  ]
}
